generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum SystemRole {
  SUPER_ADMIN
  ADMIN
  STAFF
  USER
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
}

enum SubscriptionStatus {
  REQUESTED
  PAYMENT_PENDING
  PAYMENT_VERIFICATION
  APPROVED
  ACTIVE
  TRIALING
  SUSPENDED
  EXPIRED
  REJECTED
  CANCELED
}

enum OrgRole {
  OWNER
  ORG_ADMIN
  MEMBER
}

enum DestinationType {
  PROFILE
  WHATSAPP_BUSINESS
  WHATSAPP_PRIVATE
  PHONE
  EMAIL
  WEBSITE
  VCF
  FACEBOOK
  LINKEDIN
  GITHUB
  TIKTOK
  INSTAGRAM
  X
  YOUTUBE
  TELEGRAM
  LOCATION
  FILE
  SOCIAL
  CUSTOM_FIELD
  CUSTOM_URL
}

enum ProfileFieldType {
  TEXT
  PHONE
  EMAIL
  URL
  WHATSAPP
  LOCATION
  FILE
  SOCIAL
  CUSTOM
}

enum ProfileTheme {
  CLASSIC_DARK
  CLASSIC_LIGHT
  ELEGANT_DARK
  ELEGANT_LIGHT
  BUSINESS_DARK
  BUSINESS_LIGHT
}

enum ProfileType {
  PERSONAL
  ORGANIZATION
}

enum OtpPurpose {
  LOGIN
  ACTIVATION
}

enum OtpDeliveryStatus {
  PENDING
  SENT
  FAILED
  VERIFIED
  EXPIRED
}

enum ActivationClaimStatus {
  PENDING_OTP
  VERIFIED
  CONSUMED
  EXPIRED
}

enum TagMode {
  PROFILE
  REDIRECT
}

enum TagStatus {
  ACTIVE
  PAUSED
  LOST
  DISABLED
}

enum TagEventType {
  SCAN
  REDIRECT
  PROFILE_VIEW
  STATUS_CHANGE
  CREATED
  UPDATED
}

enum CardType {
  NFC_CARD
  NFC_STICKER
  WRISTBAND
  QR_ONLY
}

enum AssignmentStatus {
  UNASSIGNED
  SELF_CLAIMED
  ADMIN_ASSIGNED
  TRANSFER_PENDING
  TRANSFERRED
  REVOKED
}

enum CardStatus {
  CREATED
  PROGRAMMED
  ACTIVE
  PAUSED
  LOST
  DISABLED
  ARCHIVED
}

enum CardInventoryStatus {
  AVAILABLE
  RESERVED
  PROGRAMMED
  ASSIGNED
  SOLD
  DAMAGED
  LOST
}

enum InventoryItemType {
  BLANK_CARD
  BLANK_STICKER
  BLANK_WRISTBAND
  QR_PRODUCT
  PACKAGING
  ACCESSORY
  OTHER
}

enum InventoryMovementType {
  PURCHASE
  PRODUCTION
  ASSIGNMENT
  SALE
  RETURN
  DAMAGE
  ADJUSTMENT
  CARD_BATCH_CREATED
  RESERVED
  SOLD
  RETURNED
  DAMAGED
  LOST
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
}

enum ProductionBatchStatus {
  DRAFT
  GENERATED
  PRINTED
  CLOSED
  CANCELLED
}

enum ProducedTagStatus {
  UNASSIGNED
  RESERVED
  ASSIGNED
  ACTIVATED
  DISABLED
  DAMAGED
}

enum VirtualCardType {
  PERSONAL
  PROFESSIONAL
  CREATOR
  BUSINESS
}

enum VirtualCardStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum WalletPlatform {
  GOOGLE
  APPLE
}

enum WalletPassStatus {
  PENDING
  ACTIVE
  DISABLED
  ERROR
}

enum TagTransferStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  EXPIRED
}

enum PurchaseStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum OrderStatus {
  NEW
  PAYMENT_PENDING
  PAID
  PROCESSING
  DRAFT
  CONFIRMED
  PREPARING
  READY
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  REFUNDED
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

enum FriendPrivacyLevel {
  FULL_PROFILE
  CONTACT_ONLY
  SELECTED_LINKS
  BUSINESS_ONLY
  NOTHING
}

enum MessageReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

enum FeatureRequestStatus {
  NEW
  REVIEWING
  PLANNED
  IN_PROGRESS
  RELEASED
  REJECTED
}

model User {
  id                       String                   @id @default(cuid())
  username                 String?                  @unique
  name                     String?
  email                    String                   @unique
  emailVerified            DateTime?
  image                    String?
  passwordHash             String?
  phone                    String?                  @unique
  phoneVerifiedAt          DateTime?
  role                     SystemRole               @default(USER)
  status                   AccountStatus            @default(ACTIVE)
  locale                   String?
  lastLoginAt              DateTime?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  accounts                 Account[]
  sessions                 Session[]
  profiles                 Profile[]
  destinations             Destination[]
  ownedTags                Tag[]                    @relation("TagOwner")
  organizationsOwned       Organization[]           @relation("OrganizationOwner")
  memberships              Membership[]
  subscriptions            UserPlan[]
  limitOverride            UserLimitOverride?
  profileFields            ProfileField[]
  uploads                  UploadedFile[]           @relation("UploadedBy")
  auditLogs                AuditLog[]               @relation("AuditActor")
  ownedCards               Card[]                   @relation("CardOwner")
  createdCardBatches       CardBatch[]              @relation("CardBatchCreator")
  createdProductionBatches ProductionBatch[]        @relation("ProductionBatchCreator")
  assignedProducedTags     ProducedTag[]            @relation("ProducedTagAssignee")
  virtualCards             VirtualCard[]
  tagTransfersFrom         TagTransfer[]            @relation("TagTransferFrom")
  tagTransfersTo           TagTransfer[]            @relation("TagTransferTo")
  onboardingProgress       OnboardingProgress?
  inventoryMovements       InventoryMovement[]      @relation("InventoryMovementCreator")
  createdPurchases         Purchase[]               @relation("PurchaseCreator")
  createdExpenses          Expense[]                @relation("ExpenseCreator")
  createdOrders            Order[]                  @relation("OrderCreator")
  customer                 Customer?
  activationClaims         ActivationClaimSession[]
  authTickets              AuthTicket[]
  mobileRefreshTokens      MobileRefreshToken[]
  friendshipsA             Friendship[]            @relation("FriendshipUserA")
  friendshipsB             Friendship[]            @relation("FriendshipUserB")
  friendshipRequests       Friendship[]            @relation("FriendshipRequester")
  friendshipBlocks         Friendship[]            @relation("FriendshipBlocker")
  privacyRulesOwned        FriendPrivacyRule[]      @relation("PrivacyRuleOwner")
  privacyRulesReceived     FriendPrivacyRule[]      @relation("PrivacyRuleFriend")
  chatMemberships          ChatMember[]
  sentMessages             Message[]
  messageReports           MessageReport[]          @relation("MessageReporter")
  moderatedMessageReports  MessageReport[]          @relation("MessageReportReviewer")
  featureRequests          FeatureRequest[]
  featureVotes             FeatureVote[]
  featureComments          FeatureComment[]
}

model Plan {
  id                    String     @id @default(cuid())
  name                  String
  nameAr                String?
  nameEn                String?
  slug                  String     @unique
  description           String?
  descriptionAr         String?
  descriptionEn         String?
  isActive              Boolean    @default(true)
  sortOrder             Int        @default(0)
  maxProfiles           Int        @default(1)
  maxVirtualCards       Int        @default(1)
  maxLinks              Int        @default(5)
  maxCustomFields       Int        @default(3)
  maxTags               Int        @default(1)
  maxCards              Int        @default(1)
  maxUploads            Int        @default(0)
  maxFiles              Int        @default(0)
  maxStorageBytes       BigInt     @default(0)
  allowCustomSlug       Boolean    @default(false)
  customSlugAllowed     Boolean    @default(false)
  allowThemes           Boolean    @default(false)
  allowCustomTheme      Boolean    @default(false)
  allowAnalytics        Boolean    @default(false)
  analyticsAllowed      Boolean    @default(false)
  availableProfileTypes Json?
  availableThemes       Json?
  allowFileUploads      Boolean    @default(false)
  allowCustomIcons      Boolean    @default(false)
  allowBusinessCards    Boolean    @default(false)
  allowWalletPasses     Boolean    @default(false)
  allowCustomLinks      Boolean    @default(false)
  allowInstallableProfiles Boolean @default(false)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  subscriptions         UserPlan[]
}

model UserPlan {
  id        String             @id @default(cuid())
  userId    String
  planId    String
  status    SubscriptionStatus @default(ACTIVE)
  startsAt  DateTime           @default(now())
  endsAt    DateTime?
  adminNote String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([userId, status])
  @@index([planId])
}

model UserLimitOverride {
  id                    String   @id @default(cuid())
  userId                String   @unique
  maxProfiles           Int?
  maxVirtualCards       Int?
  maxLinks              Int?
  maxCustomFields       Int?
  maxTags               Int?
  maxCards              Int?
  maxUploads            Int?
  maxFiles              Int?
  maxStorageBytes       BigInt?
  allowCustomSlug       Boolean?
  customSlugAllowed     Boolean?
  allowThemes           Boolean?
  allowCustomTheme      Boolean?
  allowAnalytics        Boolean?
  analyticsAllowed      Boolean?
  availableProfileTypes Json?
  availableThemes       Json?
  allowFileUploads      Boolean?
  allowCustomIcons      Boolean?
  allowBusinessCards    Boolean?
  allowWalletPasses     Boolean?
  allowCustomLinks      Boolean?
  allowInstallableProfiles Boolean?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  ownerId      String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  owner        User          @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  memberships  Membership[]
  profiles     Profile[]
  destinations Destination[]
  tags         Tag[]
  cards        Card[]
  cardBatches  CardBatch[]
  virtualCards VirtualCard[]
}

model Membership {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model Profile {
  id                   String           @id @default(cuid())
  userId               String
  organizationId       String?
  slug                 String?          @unique
  displayName          String
  type                 ProfileType      @default(PERSONAL)
  primaryLanguage      String           @default("ar")
  firstName            String?
  lastName             String?
  displayNameAr        String?
  displayNameEn        String?
  title                String?
  jobTitleAr           String?
  jobTitleEn           String?
  company              String?
  bio                  String?
  bioAr                String?
  bioEn                String?
  organizationNameAr   String?
  organizationNameEn   String?
  industryAr           String?
  industryEn           String?
  descriptionAr        String?
  descriptionEn        String?
  avatarUrl            String?
  avatarStorageKey     String?
  coverUrl             String?
  coverStorageKey      String?
  logoUrl              String?
  logoStorageKey       String?
  phone                String?
  alternatePhone       String?
  whatsappBusiness     String?
  whatsappPrivate      String?
  email                String?
  website              String?
  facebook             String?
  linkedin             String?
  github               String?
  tiktok               String?
  vcfUrl               String?
  locationText         String?
  addressAr            String?
  addressEn            String?
  contactNotesAr       String?
  contactNotesEn       String?
  isPublic             Boolean          @default(true)
  theme                ProfileTheme     @default(CLASSIC_DARK)
  avatarCrop           Json?
  coverCrop            Json?
  showAvatar           Boolean          @default(true)
  showCover            Boolean          @default(true)
  showDisplayName      Boolean          @default(true)
  showTitle            Boolean          @default(true)
  showBio              Boolean          @default(true)
  showPhone            Boolean          @default(true)
  showEmail            Boolean          @default(true)
  showWebsite          Boolean          @default(true)
  showLocation         Boolean          @default(true)
  showWhatsappBusiness Boolean          @default(true)
  showWhatsappPrivate  Boolean          @default(true)
  showSocialLinks      Boolean          @default(true)
  showCustomFields     Boolean          @default(true)
  showUploadedFiles    Boolean          @default(true)
  showSaveContact      Boolean          @default(true)
  allowInstallable     Boolean          @default(false)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization         Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  destinations         Destination[]
  tags                 Tag[]
  cards                Card[]
  fields               ProfileField[]
  uploads              UploadedFile[]
  services             ProfileService[]
  branches             ProfileBranch[]
  virtualCard          VirtualCard?

  @@index([userId])
  @@index([organizationId])
  @@index([slug])
}

model ProfileField {
  id            String           @id @default(cuid())
  profileId     String
  userId        String
  label         String
  labelAr       String?
  labelEn       String?
  value         String
  type          ProfileFieldType @default(TEXT)
  iconKey       String?
  customIconUrl String?
  actionUrl     String?
  isVisible     Boolean          @default(true)
  sortOrder     Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  profile       Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([profileId, isVisible, sortOrder])
  @@index([userId])
}

model UploadedFile {
  id                 String    @id @default(cuid())
  profileId          String?
  uploaderUserId     String
  storageKey         String    @unique
  publicUrl          String
  originalFilename   String
  originalName       String?
  mimeType           String
  sizeBytes          BigInt
  title              String?
  displayTitleAr     String?
  displayTitleEn     String?
  isVisible          Boolean   @default(true)
  sortOrder          Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  profile            Profile?  @relation(fields: [profileId], references: [id], onDelete: SetNull)
  uploader           User      @relation("UploadedBy", fields: [uploaderUserId], references: [id], onDelete: Cascade)
  expenseAttachments Expense[]
  chatMessages       Message[]

  @@index([uploaderUserId, createdAt])
  @@index([profileId, isVisible])
}

model Friendship {
  id            String           @id @default(cuid())
  userAId       String
  userBId       String
  requestedById String
  blockedById   String?
  status        FriendshipStatus @default(PENDING)
  favoriteA     Boolean          @default(false)
  favoriteB     Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  userA         User             @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB         User             @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)
  requestedBy   User             @relation("FriendshipRequester", fields: [requestedById], references: [id], onDelete: Cascade)
  blockedBy     User?            @relation("FriendshipBlocker", fields: [blockedById], references: [id], onDelete: SetNull)

  @@unique([userAId, userBId])
  @@index([userAId, status])
  @@index([userBId, status])
}

model FriendPrivacyRule {
  id                     String             @id @default(cuid())
  ownerId                String
  friendId               String
  level                  FriendPrivacyLevel @default(FULL_PROFILE)
  selectedDestinationIds Json               @default("[]")
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  owner                  User               @relation("PrivacyRuleOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  friend                 User               @relation("PrivacyRuleFriend", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([ownerId, friendId])
  @@index([friendId])
}

model Chat {
  id        String       @id @default(cuid())
  directKey String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  members   ChatMember[]
  messages  Message[]
}

model ChatMember {
  id         String    @id @default(cuid())
  chatId     String
  userId     String
  lastReadAt DateTime?
  muted      Boolean   @default(false)
  joinedAt   DateTime  @default(now())
  chat       Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId, chatId])
}

model Message {
  id               String          @id @default(cuid())
  chatId           String
  senderId         String
  body             String?
  attachmentFileId String?
  createdAt        DateTime        @default(now())
  chat             Chat            @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender           User            @relation(fields: [senderId], references: [id], onDelete: Restrict)
  attachment       UploadedFile?   @relation(fields: [attachmentFileId], references: [id], onDelete: SetNull)
  reports          MessageReport[]

  @@index([chatId, createdAt])
  @@index([senderId])
}

model MessageReport {
  id           String              @id @default(cuid())
  messageId    String
  reporterId   String
  reason       String
  status       MessageReportStatus @default(OPEN)
  reviewedById String?
  reviewNote   String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  message      Message             @relation(fields: [messageId], references: [id], onDelete: Restrict)
  reporter     User                @relation("MessageReporter", fields: [reporterId], references: [id], onDelete: Restrict)
  reviewedBy   User?               @relation("MessageReportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([messageId, reporterId])
  @@index([status, createdAt])
}

model FeatureRequest {
  id            String               @id @default(cuid())
  authorId      String
  title         String
  description   String
  status        FeatureRequestStatus @default(NEW)
  adminResponse String?
  mergedIntoId  String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  author        User                 @relation(fields: [authorId], references: [id], onDelete: Restrict)
  mergedInto    FeatureRequest?      @relation("MergedFeatureRequests", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedItems   FeatureRequest[]     @relation("MergedFeatureRequests")
  votes         FeatureVote[]
  comments      FeatureComment[]

  @@index([status, createdAt])
  @@index([mergedIntoId])
}

model FeatureVote {
  id               String         @id @default(cuid())
  featureRequestId String
  userId           String
  createdAt        DateTime       @default(now())
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([featureRequestId, userId])
  @@index([userId])
}

model FeatureComment {
  id               String         @id @default(cuid())
  featureRequestId String
  authorId         String
  body             String
  createdAt        DateTime       @default(now())
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  author           User           @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([featureRequestId, createdAt])
}

model Destination {
  id                   String          @id @default(cuid())
  userId               String
  organizationId       String?
  profileId            String?
  title                String
  titleAr              String?
  titleEn              String?
  type                 DestinationType
  url                  String
  icon                 String?
  iconKey              String?
  customIconUrl        String?
  customIconStorageKey String?
  customIconType       String?
  linkPlatformId       String?
  isActive             Boolean         @default(true)
  isVisible            Boolean         @default(true)
  sortOrder            Int             @default(0)
  isOfflineCapable     Boolean         @default(false)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization         Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  profile              Profile?        @relation(fields: [profileId], references: [id], onDelete: SetNull)
  activeForTags        Tag[]           @relation("ActiveDestination")
  activeForCards       Card[]          @relation("CardActiveDestination")
  linkPlatform         LinkPlatform?   @relation(fields: [linkPlatformId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
  @@index([profileId])
  @@index([linkPlatformId])
}

model Tag {
  id                  String        @id @default(cuid())
  token               String        @unique
  shortCode           String        @unique
  ownerId             String
  organizationId      String?
  profileId           String?
  activeDestinationId String?
  name                String
  mode                TagMode       @default(PROFILE)
  status              TagStatus     @default(ACTIVE)
  programmedAt        DateTime?
  lockedAt            DateTime?
  lastScannedAt       DateTime?
  scanCount           Int           @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  owner               User          @relation("TagOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  organization        Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  profile             Profile?      @relation(fields: [profileId], references: [id], onDelete: SetNull)
  activeDestination   Destination?  @relation("ActiveDestination", fields: [activeDestinationId], references: [id], onDelete: SetNull)
  events              TagEvent[]
  aliases             TagAlias[]

  @@index([token])
  @@index([shortCode])
  @@index([ownerId])
  @@index([status])
  @@index([organizationId])
}

model TagAlias {
  code      String   @id
  tagId     String
  createdAt DateTime @default(now())
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@index([tagId])
}

model TagEvent {
  id        String       @id @default(cuid())
  tagId     String
  type      TagEventType
  createdAt DateTime     @default(now())
  tag       Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@index([tagId, createdAt])
}

model CardBatch {
  id                   String           @id @default(cuid())
  name                 String
  supplierId           String?
  inventoryItemId      String?
  cardType             CardType
  quantity             Int
  serialPrefix         String
  startingSerialNumber Int
  publicSlugPrefix     String
  unitPurchaseCost     Decimal          @default(0) @db.Decimal(14, 2)
  unitProgrammingCost  Decimal          @default(0) @db.Decimal(14, 2)
  unitPackagingCost    Decimal          @default(0) @db.Decimal(14, 2)
  expectedSellingPrice Decimal          @default(0) @db.Decimal(14, 2)
  notes                String?
  createdBy            String
  createdAt            DateTime         @default(now())
  supplier             Supplier?        @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  inventoryItem        InventoryItem?   @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  creator              User             @relation("CardBatchCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  cards                Card[]
  organization         Organization?    @relation(fields: [organizationId], references: [id])
  organizationId       String?
  productionBatch      ProductionBatch?

  @@index([supplierId])
  @@index([createdAt])
}

model Card {
  id                        String                   @id @default(cuid())
  serialNumber              String                   @unique
  publicSlug                String                   @unique
  publicToken               String                   @unique
  activationTokenHash       String                   @unique
  activationTokenConsumedAt DateTime?
  cardType                  CardType
  batchId                   String?
  ownerId                   String?
  organizationId            String?
  profileId                 String?
  virtualCardId             String?
  activeDestinationId       String?
  assignmentStatus          AssignmentStatus         @default(UNASSIGNED)
  cardStatus                CardStatus               @default(CREATED)
  inventoryStatus           CardInventoryStatus      @default(AVAILABLE)
  programmedAt              DateTime?
  lockedAt                  DateTime?
  assignedAt                DateTime?
  activatedAt               DateTime?
  lastOpenedAt              DateTime?
  openCount                 Int                      @default(0)
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  batch                     CardBatch?               @relation(fields: [batchId], references: [id], onDelete: SetNull)
  owner                     User?                    @relation("CardOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  organization              Organization?            @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  profile                   Profile?                 @relation(fields: [profileId], references: [id], onDelete: SetNull)
  virtualCard               VirtualCard?             @relation(fields: [virtualCardId], references: [id], onDelete: SetNull)
  activeDestination         Destination?             @relation("CardActiveDestination", fields: [activeDestinationId], references: [id], onDelete: SetNull)
  dailyOpens                CardOpenDaily[]
  orderItems                OrderItem[]
  activationClaims          ActivationClaimSession[]
  activationAttempts        ActivationAttempt[]
  producedTag               ProducedTag?
  transfers                 TagTransfer[]

  @@index([batchId])
  @@index([ownerId])
  @@index([organizationId])
  @@index([virtualCardId])
  @@index([assignmentStatus, cardStatus])
  @@index([cardStatus])
  @@index([inventoryStatus])
}

model ProfileService {
  id            String   @id @default(cuid())
  profileId     String
  nameAr        String?
  nameEn        String?
  descriptionAr String?
  descriptionEn String?
  url           String?
  iconKey       String?
  isVisible     Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, isVisible, sortOrder])
}

model ProfileBranch {
  id        String   @id @default(cuid())
  profileId String
  nameAr    String?
  nameEn    String?
  addressAr String?
  addressEn String?
  phone     String?
  mapUrl    String?
  isVisible Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, isVisible, sortOrder])
}

model ActivationClaimSession {
  id                  String                @id @default(cuid())
  sessionTokenHash    String                @unique
  activationTokenHash String
  cardId              String
  userId              String?
  phone               String?
  status              ActivationClaimStatus @default(PENDING_OTP)
  attemptCount        Int                   @default(0)
  expiresAt           DateTime
  verifiedAt          DateTime?
  consumedAt          DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  card                Card                  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user                User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  otpChallenges       OtpChallenge[]

  @@index([cardId, status])
  @@index([expiresAt])
}

model ActivationAttempt {
  id        String   @id @default(cuid())
  cardId    String
  success   Boolean
  createdAt DateTime @default(now())
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, createdAt])
}

model OtpChallenge {
  id                String                  @id @default(cuid())
  phone             String
  purpose           OtpPurpose
  claimSessionId    String?
  otpHash           String
  expiresAt         DateTime
  attempts          Int                     @default(0)
  maxAttempts       Int                     @default(5)
  consumedAt        DateTime?
  deliveryStatus    OtpDeliveryStatus       @default(PENDING)
  provider          String
  providerMessageId String?
  requestIpHash     String?
  lastSentAt        DateTime                @default(now())
  createdAt         DateTime                @default(now())
  claimSession      ActivationClaimSession? @relation(fields: [claimSessionId], references: [id], onDelete: Cascade)

  @@index([phone, createdAt])
  @@index([requestIpHash, createdAt])
  @@index([claimSessionId])
  @@index([expiresAt])
}

model OtpSendLog {
  id           String            @id @default(cuid())
  phoneHash    String
  purpose      OtpPurpose
  status       OtpDeliveryStatus
  provider     String
  responseCode String?
  messageId    String?
  cost         String?
  createdAt    DateTime          @default(now())

  @@index([phoneHash, createdAt])
}

model AuthTicket {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model MobileRefreshToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  familyId   String
  userId     String
  deviceName String?
  expiresAt  DateTime
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([familyId])
  @@index([expiresAt])
}

model CardOpenDaily {
  id        String   @id @default(cuid())
  cardId    String
  date      DateTime @db.Date
  openCount Int      @default(0)
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, date])
  @@index([date])
}

model Supplier {
  id             String          @id @default(cuid())
  name           String
  contactName    String?
  phone          String?
  email          String?
  address        String?
  notes          String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  inventoryItems InventoryItem[]
  cardBatches    CardBatch[]
  purchases      Purchase[]
}

model InventoryItem {
  id                String              @id @default(cuid())
  sku               String              @unique
  nameAr            String
  nameEn            String
  type              InventoryItemType
  supplierId        String?
  quantityOnHand    Int                 @default(0)
  quantityReserved  Int                 @default(0)
  reorderLevel      Int                 @default(0)
  unitCost          Decimal             @default(0) @db.Decimal(14, 2)
  sellingPrice      Decimal             @default(0) @db.Decimal(14, 2)
  imageUrl          String?
  imageStorageKey   String?
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  supplier          Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  movements         InventoryMovement[]
  purchaseItems     PurchaseItem[]
  orderItems        OrderItem[]
  cardBatches       CardBatch[]
  batches           InventoryBatch[]
  productionBatches ProductionBatch[]

  @@index([supplierId])
  @@index([quantityOnHand])
}

model ProductionBatch {
  id                String                @id @default(cuid())
  batchCode         String                @unique
  productId         String
  quantity          Int
  status            ProductionBatchStatus @default(GENERATED)
  createdById       String
  legacyCardBatchId String?               @unique
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  product           InventoryItem         @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdBy         User                  @relation("ProductionBatchCreator", fields: [createdById], references: [id], onDelete: Restrict)
  legacyCardBatch   CardBatch?            @relation(fields: [legacyCardBatchId], references: [id], onDelete: SetNull)
  tags              ProducedTag[]

  @@index([productId, createdAt])
  @@index([status, createdAt])
}

model ProducedTag {
  id                  String            @id @default(cuid())
  batchId             String
  cardId              String?           @unique
  immutableToken      String            @unique
  shortCode           String?
  permanentUrl        String            @unique
  activationCode      String            @unique
  activationTokenHash String            @unique
  status              ProducedTagStatus @default(UNASSIGNED)
  assignedUserId      String?
  activatedAt         DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  batch               ProductionBatch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  card                Card?             @relation(fields: [cardId], references: [id], onDelete: SetNull)
  assignedUser        User?             @relation("ProducedTagAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)

  @@index([batchId, status])
  @@index([assignedUserId, status])
  @@index([shortCode])
}

model VirtualCard {
  id             String            @id @default(cuid())
  userId         String
  organizationId String?
  name           String
  type           VirtualCardType   @default(PERSONAL)
  profileId      String            @unique
  themeId        String?
  isDefault      Boolean           @default(false)
  status         VirtualCardStatus @default(ACTIVE)
  avatarKind     String?
  avatarValue    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization?     @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  profile        Profile           @relation(fields: [profileId], references: [id], onDelete: Cascade)
  template       ProfileTemplate?  @relation(fields: [themeId], references: [id], onDelete: SetNull)
  walletPasses   WalletPass[]
  cards          Card[]

  @@index([userId, status])
  @@index([organizationId])
  @@index([themeId])
}

model LinkPlatform {
  id                String        @id @default(cuid())
  nameAr            String
  nameEn            String
  slug              String        @unique
  iconKey           String
  customIconUrl     String?
  placeholder       String
  validationPattern String?
  validationRules   Json?
  category          String
  inputType         String        @default("FULL_URL")
  urlTemplate       String?
  androidAppUrl     String?
  iosAppUrl         String?
  webFallback       String?
  helpAr            String?
  helpEn            String?
  isActive          Boolean       @default(true)
  sortOrder         Int           @default(0)
  allowCustomLabel  Boolean       @default(false)
  allowCustomIcon   Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  destinations      Destination[]

  @@index([isActive, sortOrder])
}

model WalletPass {
  id               String           @id @default(cuid())
  virtualCardId    String
  platform         WalletPlatform
  externalObjectId String?
  serialNumber     String           @unique
  status           WalletPassStatus @default(PENDING)
  lastGeneratedAt  DateTime?
  lastUpdatedAt    DateTime?
  createdAt        DateTime         @default(now())
  virtualCard      VirtualCard      @relation(fields: [virtualCardId], references: [id], onDelete: Cascade)

  @@unique([virtualCardId, platform])
  @@index([platform, status])
}

model TagTransfer {
  id           String            @id @default(cuid())
  tagId        String
  fromUserId   String
  toUserId     String?
  invitedEmail String?
  status       TagTransferStatus @default(PENDING)
  expiresAt    DateTime
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  tag          Card              @relation(fields: [tagId], references: [id], onDelete: Restrict)
  fromUser     User              @relation("TagTransferFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser       User?             @relation("TagTransferTo", fields: [toUserId], references: [id], onDelete: SetNull)

  @@index([fromUserId, status])
  @@index([toUserId, status])
  @@index([invitedEmail, status])
  @@index([tagId, status])
}

model ProfileTemplate {
  id              String        @id @default(cuid())
  nameAr          String
  nameEn          String
  slug            String        @unique
  category        String
  minimumPlan     String
  previewImageUrl String?
  configuration   Json
  isActive        Boolean       @default(true)
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  virtualCards    VirtualCard[]

  @@index([isActive, sortOrder])
  @@index([minimumPlan])
}

model OnboardingProgress {
  id          String    @id @default(cuid())
  userId      String    @unique
  currentStep Int       @default(1)
  completedAt DateTime?
  data        Json      @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InventoryBatch {
  id                String        @id @default(cuid())
  productId         String
  batchCode         String        @unique
  producedQuantity  Int
  availableQuantity Int
  assignedQuantity  Int           @default(0)
  damagedQuantity   Int           @default(0)
  unitCost          Decimal       @db.Decimal(14, 2)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  product           InventoryItem @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([productId, createdAt])
}

model InventoryMovement {
  id              String                @id @default(cuid())
  inventoryItemId String
  type            InventoryMovementType
  quantity        Int
  unitCost        Decimal?              @db.Decimal(14, 2)
  referenceType   String?
  referenceId     String?
  notes           String?
  createdBy       String
  createdAt       DateTime              @default(now())
  inventoryItem   InventoryItem         @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  creator         User                  @relation("InventoryMovementCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([inventoryItemId, createdAt])
  @@index([referenceType, referenceId])
}

model Purchase {
  id            String         @id @default(cuid())
  supplierId    String
  invoiceNumber String?
  status        PurchaseStatus @default(DRAFT)
  subtotal      Decimal        @default(0) @db.Decimal(14, 2)
  shippingCost  Decimal        @default(0) @db.Decimal(14, 2)
  customsCost   Decimal        @default(0) @db.Decimal(14, 2)
  otherCost     Decimal        @default(0) @db.Decimal(14, 2)
  totalCost     Decimal        @default(0) @db.Decimal(14, 2)
  paidAmount    Decimal        @default(0) @db.Decimal(14, 2)
  purchaseDate  DateTime
  receivedDate  DateTime?
  notes         String?
  createdBy     String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  supplier      Supplier       @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  creator       User           @relation("PurchaseCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  items         PurchaseItem[]

  @@index([supplierId, purchaseDate])
  @@index([status])
}

model PurchaseItem {
  id              String        @id @default(cuid())
  purchaseId      String
  inventoryItemId String
  quantity        Int
  unitCost        Decimal       @db.Decimal(14, 2)
  totalCost       Decimal       @db.Decimal(14, 2)
  purchase        Purchase      @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([purchaseId])
  @@index([inventoryItemId])
}

model ExpenseCategory {
  id       String    @id @default(cuid())
  nameAr   String
  nameEn   String
  isActive Boolean   @default(true)
  expenses Expense[]
}

model Expense {
  id               String          @id @default(cuid())
  categoryId       String
  title            String
  description      String?
  amount           Decimal         @db.Decimal(14, 2)
  expenseDate      DateTime
  paymentMethod    String?
  referenceNumber  String?
  attachmentFileId String?
  createdBy        String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  category         ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  attachment       UploadedFile?   @relation(fields: [attachmentFileId], references: [id], onDelete: SetNull)
  creator          User            @relation("ExpenseCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([categoryId, expenseDate])
}

model Customer {
  id               String   @id @default(cuid())
  userId           String?  @unique
  name             String
  phone            String?
  email            String?
  organizationName String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  orders           Order[]

  @@index([phone])
}

model Order {
  id            String        @id @default(cuid())
  customerId    String
  status        OrderStatus   @default(DRAFT)
  subtotal      Decimal       @default(0) @db.Decimal(14, 2)
  discount      Decimal       @default(0) @db.Decimal(14, 2)
  shippingCost  Decimal       @default(0) @db.Decimal(14, 2)
  total         Decimal       @default(0) @db.Decimal(14, 2)
  paidAmount    Decimal       @default(0) @db.Decimal(14, 2)
  paymentStatus PaymentStatus @default(UNPAID)
  notes         String?
  createdBy     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  creator       User          @relation("OrderCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  items         OrderItem[]

  @@index([customerId, createdAt])
  @@index([status, paymentStatus])
}

model OrderItem {
  id              String         @id @default(cuid())
  orderId         String
  cardId          String?
  inventoryItemId String?
  description     String
  quantity        Int
  unitPrice       Decimal        @db.Decimal(14, 2)
  total           Decimal        @db.Decimal(14, 2)
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  card            Card?          @relation(fields: [cardId], references: [id], onDelete: SetNull)
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([cardId])
}

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model BrandSettings {
  id                       String   @id @default("default")
  mainLogoUrl              String?
  mainLogoStorageKey       String?
  lightLogoUrl             String?
  lightLogoStorageKey      String?
  darkLogoUrl              String?
  darkLogoStorageKey       String?
  appIconUrl               String?
  appIconStorageKey        String?
  faviconUrl               String?
  faviconStorageKey        String?
  appleTouchIconUrl        String?
  appleTouchIconStorageKey String?
  pwaIcon192Url            String?
  pwaIcon512Url            String?
  defaultOgImageUrl        String?
  defaultOgImageStorageKey String?
  updatedAt                DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  operation String
  route     String?
  targetId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorId])
}
