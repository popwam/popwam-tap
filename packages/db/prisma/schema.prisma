generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum SystemRole {
  ADMIN
  USER
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  EXPIRED
  CANCELED
}

enum OrgRole {
  OWNER
  ORG_ADMIN
  MEMBER
}

enum DestinationType {
  PROFILE
  WHATSAPP_BUSINESS
  WHATSAPP_PRIVATE
  PHONE
  EMAIL
  WEBSITE
  VCF
  FACEBOOK
  LINKEDIN
  GITHUB
  TIKTOK
  INSTAGRAM
  X
  YOUTUBE
  TELEGRAM
  LOCATION
  FILE
  SOCIAL
  CUSTOM_FIELD
  CUSTOM_URL
}

enum ProfileFieldType {
  TEXT
  PHONE
  EMAIL
  URL
  WHATSAPP
  LOCATION
  FILE
  SOCIAL
  CUSTOM
}

enum ProfileTheme {
  CLASSIC_DARK
  CLASSIC_LIGHT
  ELEGANT_DARK
  ELEGANT_LIGHT
}

enum TagMode {
  PROFILE
  REDIRECT
}

enum TagStatus {
  ACTIVE
  PAUSED
  LOST
  DISABLED
}

enum TagEventType {
  SCAN
  REDIRECT
  PROFILE_VIEW
  STATUS_CHANGE
  CREATED
  UPDATED
}

model User {
  id                 String         @id @default(cuid())
  name               String?
  email              String         @unique
  emailVerified      DateTime?
  image              String?
  passwordHash       String?
  role               SystemRole     @default(USER)
  status             AccountStatus  @default(ACTIVE)
  locale             String?
  lastLoginAt        DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  accounts           Account[]
  sessions           Session[]
  profiles           Profile[]
  destinations       Destination[]
  ownedTags           Tag[]          @relation("TagOwner")
  organizationsOwned Organization[] @relation("OrganizationOwner")
  memberships        Membership[]
  subscriptions      UserPlan[]
  limitOverride      UserLimitOverride?
  profileFields      ProfileField[]
  uploads            UploadedFile[] @relation("UploadedBy")
  auditLogs          AuditLog[]      @relation("AuditActor")
}

model Plan {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  description      String?
  isActive         Boolean  @default(true)
  maxProfiles      Int      @default(1)
  maxLinks         Int      @default(5)
  maxCustomFields  Int      @default(3)
  maxTags          Int      @default(1)
  maxUploads       Int      @default(0)
  maxStorageBytes  BigInt   @default(0)
  allowCustomSlug  Boolean  @default(false)
  allowThemes      Boolean  @default(false)
  allowCustomTheme Boolean  @default(false)
  allowAnalytics   Boolean  @default(false)
  allowFileUploads Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  subscriptions    UserPlan[]
}

model UserPlan {
  id        String             @id @default(cuid())
  userId    String
  planId    String
  status    SubscriptionStatus @default(ACTIVE)
  startsAt  DateTime           @default(now())
  endsAt    DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  @@index([userId, status])
  @@index([planId])
}

model UserLimitOverride {
  id               String   @id @default(cuid())
  userId           String   @unique
  maxProfiles      Int?
  maxLinks         Int?
  maxCustomFields  Int?
  maxTags          Int?
  maxUploads       Int?
  maxStorageBytes  BigInt?
  allowCustomSlug  Boolean?
  allowThemes      Boolean?
  allowCustomTheme Boolean?
  allowAnalytics   Boolean?
  allowFileUploads Boolean?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Organization {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  ownerId      String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  owner        User          @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  memberships  Membership[]
  profiles     Profile[]
  destinations Destination[]
  tags         Tag[]
}

model Membership {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([organizationId, userId])
  @@index([userId])
}

model Profile {
  id                String        @id @default(cuid())
  userId            String
  organizationId    String?
  slug              String?       @unique
  displayName       String
  title             String?
  bio               String?
  avatarUrl          String?
  avatarStorageKey  String?
  coverUrl           String?
  coverStorageKey   String?
  phone              String?
  whatsappBusiness  String?
  whatsappPrivate   String?
  email              String?
  website            String?
  facebook           String?
  linkedin           String?
  github             String?
  tiktok             String?
  vcfUrl             String?
  locationText       String?
  isPublic           Boolean       @default(true)
  theme              ProfileTheme  @default(CLASSIC_DARK)
  avatarCrop         Json?
  coverCrop          Json?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization       Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  destinations       Destination[]
  tags               Tag[]
  fields             ProfileField[]
  uploads            UploadedFile[]
  @@index([userId])
  @@index([organizationId])
  @@index([slug])
}

model ProfileField {
  id            String           @id @default(cuid())
  profileId     String
  userId        String
  label         String
  value         String
  type          ProfileFieldType @default(TEXT)
  iconKey       String?
  customIconUrl String?
  actionUrl     String?
  isVisible     Boolean          @default(true)
  sortOrder     Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  profile       Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([profileId, isVisible, sortOrder])
  @@index([userId])
}

model UploadedFile {
  id               String   @id @default(cuid())
  profileId        String?
  uploaderUserId   String
  storageKey       String   @unique
  publicUrl        String
  originalFilename String
  mimeType         String
  sizeBytes        BigInt
  title            String?
  isVisible        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  profile          Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  uploader         User     @relation("UploadedBy", fields: [uploaderUserId], references: [id], onDelete: Cascade)
  @@index([uploaderUserId, createdAt])
  @@index([profileId, isVisible])
}

model Destination {
  id               String          @id @default(cuid())
  userId           String
  organizationId   String?
  profileId        String?
  title            String
  type             DestinationType
  url              String
  icon             String?
  iconKey          String?
  customIconUrl    String?
  isActive         Boolean         @default(true)
  isOfflineCapable Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization     Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  profile          Profile?        @relation(fields: [profileId], references: [id], onDelete: SetNull)
  activeForTags    Tag[]            @relation("ActiveDestination")
  @@index([userId])
  @@index([organizationId])
  @@index([profileId])
}

model Tag {
  id                  String       @id @default(cuid())
  token               String       @unique
  shortCode           String       @unique
  ownerId             String
  organizationId      String?
  profileId           String?
  activeDestinationId String?
  name                String
  mode                 TagMode      @default(PROFILE)
  status               TagStatus    @default(ACTIVE)
  programmedAt         DateTime?
  lockedAt             DateTime?
  lastScannedAt        DateTime?
  scanCount            Int          @default(0)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  owner                User         @relation("TagOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  organization         Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  profile              Profile?     @relation(fields: [profileId], references: [id], onDelete: SetNull)
  activeDestination    Destination? @relation("ActiveDestination", fields: [activeDestinationId], references: [id], onDelete: SetNull)
  events               TagEvent[]
  aliases              TagAlias[]
  @@index([token])
  @@index([shortCode])
  @@index([ownerId])
  @@index([status])
  @@index([organizationId])
}

model TagAlias {
  code      String   @id
  tagId     String
  createdAt DateTime @default(now())
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@index([tagId])
}

model TagEvent {
  id        String       @id @default(cuid())
  tagId     String
  type      TagEventType
  ipAddress String?
  userAgent String?
  referrer  String?
  metadata  Json?
  createdAt DateTime     @default(now())
  tag       Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@index([tagId, createdAt])
}

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  operation String
  route     String?
  targetId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  @@index([createdAt])
  @@index([actorId])
}
