APP_NAME="POPWAM Tap"
NODE_ENV="production"

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require"

NEXTAUTH_SECRET="CHANGE_TO_LONG_RANDOM_SECRET_64_CHARS_MINIMUM"
NEXTAUTH_URL="https://popwam-tap.vercel.app"
NEXT_PUBLIC_APP_URL="https://popwam-tap.vercel.app"

BCRYPT_SALT_ROUNDS="12"

ADMIN_EMAIL="admin@popwam.com"
ADMIN_PASSWORD="ChangeMe123!"

DEMO_USER_EMAIL="mmdoh@popwam.com"
DEMO_USER_PASSWORD="ChangeMe123!"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="popwam-tap"
R2_ENDPOINT="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"
R2_PUBLIC_BASE_URL=""
R2_PUBLIC_FOLDER="public"
R2_PRIVATE_FOLDER="private"

MAX_IMAGE_UPLOAD_MB="5"
ALLOWED_IMAGE_TYPES="image/jpeg,image/png,image/webp"
