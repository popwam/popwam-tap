APP_NAME="POP by POPWAM"
NODE_ENV="production"

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require"

NEXTAUTH_SECRET="CHANGE_TO_LONG_RANDOM_SECRET_64_CHARS_MINIMUM"
MOBILE_TOKEN_SECRET="CHANGE_TO_DISTINCT_LONG_RANDOM_SECRET_64_CHARS_MINIMUM"
APP_URL="https://pop.popwam.com"
PUBLIC_URL="https://go.popwam.com"
NEXTAUTH_URL="https://pop.popwam.com"
NEXT_PUBLIC_APP_URL="https://go.popwam.com"
NEXT_PUBLIC_WEB_APP_URL="https://pop.popwam.com"
APP_HOST="pop.popwam.com"
PUBLIC_HOST="go.popwam.com"

BCRYPT_SALT_ROUNDS="12"

ADMIN_EMAIL="admin@popwam.com"
ADMIN_PASSWORD="CHANGE_TO_STRONG_ONE_TIME_SEED_PASSWORD"
ADMIN_FORCE_PASSWORD_RESET=false
ADMIN_ENSURE_PRODUCTION=false

DEMO_USER_EMAIL="mmdoh@popwam.com"
DEMO_USER_PASSWORD="CHANGE_TO_DISTINCT_ONE_TIME_SEED_PASSWORD"
ALLOW_PRODUCTION_SEED="false"

# Google is a connected account only; it is not a primary sign-in provider.

# Phone OTP
DEFAULT_LOCALE="en"
SUPPORTED_LOCALES="en,ar"
FALLBACK_LOCALE="en"
DEFAULT_PHONE_COUNTRY_ISO2="EG"
PHONE_OTP_PRIMARY_CHANNEL="sms"
PHONE_OTP_FALLBACK_CHANNEL="whatsapp"
PHONE_OTP_TIMEOUT_MS="10000"
OTP_PEPPER="CHANGE_TO_ANOTHER_LONG_RANDOM_SECRET"
OTP_EXPIRY_MINUTES="5"
OTP_SEND_COOLDOWN_SECONDS="60"
OTP_HOURLY_SEND_LIMIT="5"
OTP_MAX_ATTEMPTS="10"
ACTIVATION_SESSION_MINUTES="15"
ACTIVATION_MAX_ATTEMPTS="8"

# SMS provider. Keep credentials server-side and use Railway variables in deployed environments.
SMS_PROVIDER="smsmisr"
SMSMISR_USERNAME=""
SMSMISR_PASSWORD=""
SMSMISR_SENDER_TOKEN=""
SMSMISR_TEMPLATE_TOKEN=""
SMSMISR_ENVIRONMENT="2"
SMSMISR_BASE_URL="https://smsmisr.com/api/OTP/"
SMS_TIMEOUT_MS="10000"

# Meta WhatsApp Business authentication templates. Server-side only.
WHATSAPP_OTP_ENABLED="false"
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_AUTH_TEMPLATE_NAME=""
WHATSAPP_AUTH_TEMPLATE_LANGUAGE="en_US"

# WebAuthn / Passkeys
PASSKEY_RP_ID="pop.popwam.com"
PASSKEY_ORIGIN="https://pop.popwam.com"
PASSKEY_RP_NAME="POP by POPWAM"

# Connected accounts. Tokens are encrypted with this server-only key.
INTEGRATION_TOKEN_ENCRYPTION_KEY=""
META_GRAPH_API_VERSION="v23.0"
META_ENABLED="false"
META_APP_ID=""
META_APP_SECRET=""
META_REDIRECT_URI="https://pop.popwam.com/api/integrations/meta/callback"
# Optional reviewed capabilities: facebook_pages,instagram,threads,whatsapp_business
META_OAUTH_CAPABILITIES=""
TIKTOK_ENABLED="false"
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
TIKTOK_REDIRECT_URI="https://pop.popwam.com/api/integrations/tiktok/callback"
GOOGLE_CONNECTED_ENABLED="false"
GOOGLE_CONNECTED_CLIENT_ID=""
GOOGLE_CONNECTED_CLIENT_SECRET=""
GOOGLE_CONNECTED_REDIRECT_URI="https://pop.popwam.com/api/integrations/google/callback"
LINKEDIN_ENABLED="false"
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_REDIRECT_URI="https://pop.popwam.com/api/integrations/linkedin/callback"
GITHUB_ENABLED="false"
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_REDIRECT_URI="https://pop.popwam.com/api/integrations/github/callback"

# Firebase Cloud Messaging is independent of Google account linking.
FCM_ENABLED="false"
FCM_PROJECT_ID=""
FCM_CLIENT_EMAIL=""
FCM_PRIVATE_KEY=""

# Alternative webhook provider (used only when SMS_PROVIDER=webhook).
SMS_API_URL=""
SMS_API_TOKEN=""
SMS_SENDER_ID="POPWAM"

# Strict OTP testing mode. Replace placeholders only in local/staging secrets, never in Git.
STAGING="false"
OTP_TEST_MODE="false"
OTP_TEST_PHONES="<E164_TEST_PHONE_1>,<E164_TEST_PHONE_2>"
OTP_TEST_CODE=""
OTP_EXPOSE_IN_RESPONSE="false"

R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="popwam-tap"
R2_ENDPOINT="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"
R2_PUBLIC_BASE_URL="https://go.popwam.com"
R2_PUBLIC_FOLDER="public"
R2_PRIVATE_FOLDER="private"

MAX_IMAGE_UPLOAD_MB="5"
ALLOWED_IMAGE_TYPES="image/jpeg,image/png,image/webp"
# Leave blank until a signed APK is published on a POPWAM domain.
NEXT_PUBLIC_ANDROID_APK_URL=""
NEXT_PUBLIC_ANDROID_VERSION=""
NEXT_PUBLIC_ANDROID_APK_SIZE=""
NEXT_PUBLIC_ANDROID_UPDATED_AT=""
NEXT_PUBLIC_ANDROID_MIN_VERSION="Android 8.0+"
NEXT_PUBLIC_ANDROID_SHA256=""

# Google Wallet Generic Pass. Configure the class in Google Wallet Console first.
GOOGLE_WALLET_ISSUER_ID=""
GOOGLE_WALLET_ISSUER_STATUS=""
GOOGLE_WALLET_CLASS_SUFFIX="popwam_pop"
GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_WALLET_PRIVATE_KEY=""
GOOGLE_WALLET_ORIGINS="pop.popwam.com"
GOOGLE_WALLET_MODE="test"

# Apple Wallet PassKit signing. Values ending in _BASE64 are certificate/file bytes.
APPLE_WALLET_PASS_TYPE_ID="pass.com.popwam.pop"
APPLE_WALLET_TEAM_ID=""
APPLE_WALLET_SIGNER_CERT_BASE64=""
APPLE_WALLET_SIGNER_KEY_BASE64=""
APPLE_WALLET_SIGNER_KEY_PASSPHRASE=""
APPLE_WALLET_WWDR_CERT_BASE64=""
APPLE_WALLET_ICON_BASE64=""
APPLE_WALLET_WEB_SERVICE_URL=""
APPLE_WALLET_AUTH_SECRET=""
