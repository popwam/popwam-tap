{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL", "DIRECT_DATABASE_URL", "NEXTAUTH_SECRET", "NEXTAUTH_URL", "NEXT_PUBLIC_APP_URL",
    "GOOGLE_CLIENT_ID", "GOOGLE_CLIENT_SECRET", "R2_ACCOUNT_ID", "R2_ACCESS_KEY_ID",
    "R2_SECRET_ACCESS_KEY", "R2_BUCKET_NAME", "R2_ENDPOINT", "R2_PUBLIC_BASE_URL",
    "R2_PUBLIC_FOLDER", "R2_PRIVATE_FOLDER", "MAX_IMAGE_UPLOAD_MB", "ALLOWED_IMAGE_TYPES"
  ],
  "tasks": {
    "dev": { "cache": false, "persistent": true },
    "build": { "dependsOn": ["^build"], "outputs": [".next/**", "!.next/cache/**", "dist/**"] },
    "lint": { "dependsOn": ["^lint"] }
  }
}
