{
  "name": "popwam-tap",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp"
    ]
  },
  
  "scripts": {
    "dev": "turbo dev --filter=@popwam/web",
    "build": "pnpm db:generate && turbo run build",
    "lint": "turbo lint",
    "start": "node scripts/validate-production-env.mjs && pnpm --filter @popwam/web start",
    "validate:production-env": "node scripts/validate-production-env.mjs",
    "db:generate": "pnpm --filter @popwam/db prisma generate",
    "db:migrate": "pnpm --filter @popwam/db prisma migrate dev",
    "db:deploy": "pnpm --filter @popwam/db prisma migrate deploy",
    "seed": "pnpm --filter @popwam/db seed",
    "db:repair": "pnpm --filter @popwam/db repair",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.5.6"
  }
}
